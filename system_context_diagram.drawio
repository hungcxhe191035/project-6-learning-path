        <!-- Flows: Student <-> System -->
        <mxCell id="flow_student_to_system" value="1. Register / Login credentials&#xa;2. Profile updates&#xa;3. Search courses &amp; learning paths&#xa;4. Course purchase request&#xa;5. Lesson feedback &amp; Q&amp;A questions&#xa;6. Quiz answers" style="edgeStyle=orthogonalEdgeStyle;rounded=1;curved=1;html=1;endArrow=block;strokeColor=#000000;strokeWidth=1.5;fontColor=#000000;fontSize=10;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=0.15;entryY=0.15;entryDx=0;entryDy=0;" edge="1" parent="1" source="entity_student" target="system">
